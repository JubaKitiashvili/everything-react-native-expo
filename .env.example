# =============================================================================
# ERNE — Everything React Native & Expo
# Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# ERNE Dashboard & Configuration
# -----------------------------------------------------------------------------

# Project directory for dashboard and agent operations (default: cwd)
# ERNE_PROJECT_DIR=/path/to/your/project

# Dashboard server port (default: 3333)
# ERNE_DASHBOARD_PORT=3333

# Allow sandbox command execution from dashboard (set to "true" to enable)
# ERNE_ALLOW_EXECUTE=false

# Skip auto-starting the dashboard on session start
# ERNE_SKIP_DASHBOARD=true

# Hook execution profile: minimal | standard | strict
# ERNE_PROFILE=standard

# Path to custom hooks configuration JSON
# ERNE_HOOKS_CONFIG=/path/to/hooks.json

# Enable context features (session continuity, snapshots)
# ERNE_CONTEXT=true

# -----------------------------------------------------------------------------
# AI / LLM API Keys
# -----------------------------------------------------------------------------

# Required for automatic knowledge updates (changelog analysis)
ANTHROPIC_API_KEY=

# Optional — for alternative AI provider integrations
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Git / CI Integration
# -----------------------------------------------------------------------------

# GitHub personal access token (repo scope)
# Used by: worker GitHub provider, ecosystem fetcher, knowledge updater
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Task Provider API Keys (for Worker mode)
# Only configure the provider(s) you use.
# -----------------------------------------------------------------------------

# Jira
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=

# GitLab
# GITLAB_TOKEN=

# Linear
# LINEAR_API_KEY=

# ClickUp
# CLICKUP_API_KEY=
